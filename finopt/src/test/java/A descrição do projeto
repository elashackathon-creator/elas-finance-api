package com.example.financeai.controller;

import com.example.financeai.dto.ExplainRequest;
import com.example.financeai.dto.ExplainResponse;
import com.example.financeai.service.FinanceAiService;

import lombok.RequiredArgsConstructor;

import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/ai")
@RequiredArgsConstructor
public class FinanceAiController {

    private final FinanceAiService financeAiService;

    @PostMapping("/explain")
    public ResponseEntity<ExplainResponse> explainDecision(
            @RequestBody ExplainRequest request
    ) {

        ExplainResponse response =
                financeAiService.generateExplanation(request);

        return ResponseEntity.ok(response);
    }
}

Service
package com.example.financeai.service;

import com.example.financeai.dto.ExplainRequest;
import com.example.financeai.dto.ExplainResponse;

import org.springframework.stereotype.Service;

@Service
public class FinanceAiService {

    public ExplainResponse generateExplanation(ExplainRequest request) {

        double estimatedSavings =
                request.expensesToCut().size() * 200.0;

        String recommendation = """
                IA Financeira Feminina:

                Detectamos oportunidades para melhorar sua
                autonomia financeira e acelerar seus objetivos.

                Objetivo:
                """ + request.financialGoal();

        String strategy = """
                Estratégia recomendada:

                - Reduzir gastos desnecessários
                - Criar reserva de emergência
                - Investir em capacitação profissional
                - Desenvolver independência financeira
                """;

        return new ExplainResponse(
                recommendation,
                estimatedSavings,
                strategy
        );
    }
}


